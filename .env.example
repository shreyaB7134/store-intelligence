# Store Intelligence Platform - Environment Configuration
# Copy this to .env and fill in your values

# Database
POSTGRES_USER=si_user
POSTGRES_PASSWORD=si_password
POSTGRES_DB=store_intelligence
DATABASE_URL=postgresql+asyncpg://si_user:si_password@postgres:5432/store_intelligence

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand

# Store
STORE_ID=ST1008
DEFAULT_STORE_ID=ST1008

# Feed monitoring
STALE_FEED_THRESHOLD_SECONDS=300

# Anomaly thresholds
QUEUE_SPIKE_MULTIPLIER=2.0
CONVERSION_DROP_THRESHOLD=0.5
DEAD_ZONE_MINUTES=30

# POS correlation
POS_MATCH_WINDOW_SECONDS=300

# Deduplication
DEDUP_CACHE_SIZE=10000
DEDUP_CACHE_TTL_SECONDS=3600

# Dashboard
API_BASE_URL=http://api:8000
DASHBOARD_REFRESH_SECONDS=5
